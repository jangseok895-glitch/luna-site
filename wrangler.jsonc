{
  "name": "luna-site",
  "main": "src/index.js",
  "compatibility_date": "2026-07-11",

  "placement": {
    "region": "aws:ap-northeast-1"
  },

  "assets": {
    "directory": ".",
    "binding": "ASSETS",
    "run_worker_first": [
      "/analyze",
      "/api/health",
      "/api/test"
    ]
  },

  "vars": {
    "OPENAI_MODEL": "gpt-4.1-mini"
  }
}
